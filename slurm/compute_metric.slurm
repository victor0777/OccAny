#!/bin/bash
#SBATCH --job-name=compute_metric
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=16
#SBATCH --time=06:00:00
#SBATCH --array=0-0
#SBATCH --hint=nomultithread
#SBATCH -A eu-25-92
#SBATCH --partition=qgpu
#SBATCH --output=slurm/output/compute_metric_%A_%a.out
#SBATCH --error=slurm/output/compute_metric_%A_%a.err

mkdir -p slurm/output

eval "$(conda shell.bash hook)"
conda activate occany

export PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"
export EXP_LIST="${EXP_LIST:-metric_occany}"
export EXP_ID="${EXP_ID:-${SLURM_ARRAY_TASK_ID:-0}}"
export USE_MAJORITY_POOLING="${USE_MAJORITY_POOLING:-1}"
export POOLING_MODE="${POOLING_MODE:-separate}"

bash sh/compute_metric.sh
